# Copy to /etc/toolbox-logs.env on the droplet, fill in real values, then:
#     sudo chown root:root /etc/toolbox-logs.env
#     sudo chmod 600 /etc/toolbox-logs.env
# Never commit the real file. INGEST_TOKEN is the shared secret the plugin
# build also carries (#43); it gates POST /events.

PORT=8091

# Generate with: openssl rand -hex 32
INGEST_TOKEN=replace-me

# Use the toolbox_ingest password from 01_roles_and_db.sql. 5432 is the primary
# cluster — change the port if pg_lsclusters shows your main cluster elsewhere.
DATABASE_URL=postgres://toolbox_ingest:CHANGE_ME_INGEST@127.0.0.1:5432/toolbox_logs
